# Azure Agent Pro v2 — Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena los valores con los tuyos REALES
#   3. ¡NUNCA hagas commit de .env! (ya está en .gitignore)
#   4. Para WSL: ejecuta ./scripts/setup/setup-wsl.sh (setup guiado interactivo)
#
# CARGA EN WSL: añade al final de ~/.bashrc o ~/.zshrc:
#   set -a; source /ruta/a/azure-agent-pro/.env; set +a
# ─────────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════════════
# AZURE — REQUERIDO para azure-mcp y az CLI
# ════════════════════════════════════════════════════════════════════════════
# Obtener de: az account show --query '{sub:id,tenant:tenantId}'
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_TENANT_ID=your-tenant-id-here

# Service Principal (opcional — para CI/CD y OIDC)
# Crear con: az ad sp create-for-rbac --name "azure-agent-pro-sp" --role Contributor
# OIDC (recomendado): configurar en GitHub Actions con federated credentials
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here    # Solo si NO usas OIDC

# ════════════════════════════════════════════════════════════════════════════
# GITHUB — REQUERIDO para github-mcp
# ════════════════════════════════════════════════════════════════════════════
# Crear token en: https://github.com/settings/tokens
# Permisos requeridos: repo, read:user, workflow (para GitHub Actions)
# Alternativa desde gh CLI: gh auth token
GITHUB_TOKEN=ghp_your_token_here

# ════════════════════════════════════════════════════════════════════════════
# MEMORY MCP — OPCIONAL (contexto persistente entre sesiones)
# ════════════════════════════════════════════════════════════════════════════
# Si está vacío, el MCP usa $HOME/.config/mcp/memory.json por defecto
# Recomendado: especificar ruta explícita para no perder el contexto
MEMORY_FILE_PATH=${HOME}/.config/mcp/azure-agent-pro-memory.json

# ════════════════════════════════════════════════════════════════════════════
# BRAVE SEARCH — OPCIONAL (búsqueda web de documentación Azure)
# ════════════════════════════════════════════════════════════════════════════
# Obtener gratis en: https://brave.com/search/api/ (2000 queries/mes)
# Si está vacío, el brave-search-mcp no funcionará
BRAVE_API_KEY=your-brave-api-key-here

# ════════════════════════════════════════════════════════════════════════════
# AZURE AI / OPENAI — OPCIONAL (para Azure_Foundry_Pro agent)
# ════════════════════════════════════════════════════════════════════════════
# Endpoint de tu Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-aoai-resource.openai.azure.com/
# API Key (solo para dev — en prod usa Managed Identity)
AZURE_OPENAI_API_KEY=your-aoai-key-here
# Nombre del deployment (ej: gpt-4o, gpt-4o-mini)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Modelo de embeddings
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure AI Search (para RAG patterns)
AZURE_SEARCH_SERVICE=your-search-service-name
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your-search-admin-key    # Solo dev — prod usa Managed Identity
AZURE_SEARCH_INDEX_NAME=your-index-name

# ════════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE RECURSOS AZURE — para scripts de deployment
# ════════════════════════════════════════════════════════════════════════════
RESOURCE_GROUP=rg-azure-agent-pro-dev
AZURE_LOCATION=westeurope
ENVIRONMENT=dev    # dev | test | stage | prod

# Prefijo para naming convention: {PREFIX}-{env}-{location}-{resourceType}
RESOURCE_PREFIX=aap

# ════════════════════════════════════════════════════════════════════════════
# TAGS OBLIGATORIOS — aplicados a todos los recursos desplegados
# ════════════════════════════════════════════════════════════════════════════
TAG_PROJECT=AzureAgentPro
TAG_OWNER=your-team-or-email
TAG_COST_CENTER=IT-Development
TAG_MANAGED_BY=bicep

