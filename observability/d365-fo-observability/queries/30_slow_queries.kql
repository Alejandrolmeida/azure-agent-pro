customEvents
| where timestamp > ago(7d)
| where name == "LongRunningQuery"
| extend
    QueryType = tostring(customDimensions.QueryType),
    ExecutionTimeSeconds = todouble(customDimensions.ExecutionTimeSeconds),
    LegalEntity = tostring(customDimensions.LegalEntity),
    ExecutionMode = tostring(customDimensions.ExecutionMode),
    Success = tostring(customDimensions.Success)
| summarize
    SlowQueries = count(),
    AvgDurationSeconds = round(avg(ExecutionTimeSeconds), 2),
    P95DurationSeconds = round(percentile(ExecutionTimeSeconds, 95), 2),
    MaxDurationSeconds = round(max(ExecutionTimeSeconds), 2)
    by QueryType, LegalEntity, ExecutionMode
| order by SlowQueries desc
