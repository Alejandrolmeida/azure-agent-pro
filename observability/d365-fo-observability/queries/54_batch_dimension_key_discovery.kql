customEvents
| where timestamp > ago(7d)
| where name has_any ("Batch", "batch", "SysOperation")
| extend cd = parse_json(customDimensions)
| mv-expand key = bag_keys(cd)
| summarize KeyOccurrences = count() by EventName = name, DimensionKey = tostring(key)
| order by KeyOccurrences desc
| take 500
